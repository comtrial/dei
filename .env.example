# 원격 Supabase 프로젝트 연동 시 사용 (지금은 로컬만)
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Sentry — 모바일 앱 런타임 에러 로깅
# DSN 은 Sentry 프로젝트 Settings > Client Keys (DSN) 에서 발급받는다.
# 형식: https://<key>@oXXX.ingest.sentry.io/<projectId>
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=development

# Sentry sentry-cli (소스맵 업로드 등) — CI/배포 환경에서만 사용. 절대 커밋 금지.
# 다음 두 값은 OAuth/Internal Integration 자격이며 SDK DSN 과 다르다.
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Local Supabase Kakao OAuth
# Kakao Developers > REST API key / Kakao Login client secret
SUPABASE_AUTH_EXTERNAL_KAKAO_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_KAKAO_SECRET=

# Supabase Edge Functions secrets
# supabase secrets set PORTONE_STORE_ID=... PORTONE_IDENTITY_CHANNEL_KEY=... PORTONE_API_SECRET=... PHONE_HASH_SALT=...
PORTONE_STORE_ID=
PORTONE_IDENTITY_CHANNEL_KEY=
PORTONE_API_SECRET=
PHONE_HASH_SALT=
