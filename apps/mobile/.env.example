# 모바일 앱 실행 전에 이 파일을 apps/mobile/.env로 복사하세요.
#
# apps/mobile/.env 파일은 Git에 올리면 안 됩니다.
# 실제 값은 Supabase 프로젝트 담당자에게 받아서 넣으세요.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry — 모바일 런타임 에러 로깅. DSN 미설정 시 콘솔 fallback.
# DSN 은 Sentry 프로젝트 Settings > Client Keys (DSN) 에서 발급.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=development
