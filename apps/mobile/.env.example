# 모바일 앱 실행 전에 이 파일을 apps/mobile/.env 로 복사하세요.
#   cp apps/mobile/.env.example apps/mobile/.env
#
# 아래 값들은 모두 공개되어도 무방한 값입니다:
#   - Supabase 로컬 anon key 는 모든 supabase CLI 설치본이 공유하는 데모 키
#   - Sentry DSN 은 클라이언트 SDK 용 (앱 바이너리에 그대로 포함되는 식별자)
# 따라서 이 파일은 git 에 커밋되어 있고, .env 파일은 gitignore 됩니다.

# --- Supabase (로컬 dev) ---
# `pnpm db:start` 후 `pnpm exec supabase status -o env` 로 키 확인 가능.
# config.toml 의 기본 JWT 시크릿을 그대로 두면 아래 값과 일치합니다.
# 물리 디바이스로 테스트할 땐 127.0.0.1 → 개발 PC LAN IP 로 교체하세요.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# 원격 Supabase로 개발하면서 PortOne 실키를 아직 넣지 않았을 때만 true.
EXPO_PUBLIC_ENABLE_DEV_IDENTITY_BYPASS=false

# --- Sentry (deai-13/react-native 프로젝트) ---
# DSN 미설정 시 SDK 비활성화 + 콘솔 fallback 으로 동작.
# Sentry 콘솔: https://deai-13.sentry.io/projects/react-native/
EXPO_PUBLIC_SENTRY_DSN=https://3eb2cadbb6b232e459cb5bc962d506e8@o4511291332100096.ingest.us.sentry.io/4511291335049216
EXPO_PUBLIC_SENTRY_ENV=development

# 본인확인은 PortOne을 Supabase Edge Function 뒤에서 호출합니다.
# 모바일 앱에는 Supabase URL/anon key만 필요합니다.
